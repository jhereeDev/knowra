{
  "name": "knowra",
  "private": true,
  "version": "0.0.1",
  "description": "Knowra — the curiosity feed. TikTok mechanic, Wikipedia content.",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@knowra/web",
    "dev:mobile": "turbo run dev --filter=@knowra/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @knowra/db db:generate",
    "db:push": "pnpm --filter @knowra/db db:push",
    "db:migrate": "pnpm --filter @knowra/db db:migrate",
    "db:studio": "pnpm --filter @knowra/db db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.5.4",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~19.1.0",
      "@types/react-dom": "~19.1.0",
      "react-native-worklets": "0.5.1"
    }
  }
}
