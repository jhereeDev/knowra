# Neon Postgres connection string with pgvector extension enabled.
# See SETUP.md §4. Run `CREATE EXTENSION IF NOT EXISTS vector;` on the DB before first push.
DATABASE_URL=postgres://user:password@host.neon.tech/knowra?sslmode=require

# Anthropic API key for LLM hook generation (background, fire-and-forget).
# Get one at console.anthropic.com. Used by apps/web/src/lib/hooks.ts.
ANTHROPIC_API_KEY=sk-ant-...

# Wikipedia REST API requires a User-Agent identifying our contact email.
WIKIPEDIA_USER_AGENT="Knowra/0.1 (contact: dev@knowra.space)"

# Clerk — auth for web. Both required to enable sign-in flow.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Cloudflare Images — for the image CDN pipeline. When set, new image
# ingests get uploaded to CF and served via variants; mobile picks the
# CDN URL over the original Wikipedia URL. Without these, images flow
# directly from Wikimedia Commons.
CF_IMAGES_ACCOUNT_ID=
CF_IMAGES_API_TOKEN=
