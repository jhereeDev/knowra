# Set to your dev machine's LAN IP so a physical phone can reach the
# Next.js API. localhost only works for simulators.
EXPO_PUBLIC_API_URL=http://192.168.50.250:3000

# Clerk publishable key (mobile side). When set, the app gates with a
# sign-in screen; when absent, the app runs anonymously (saved/streak
# stay local-only).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
