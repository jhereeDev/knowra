# /opt/knowra/.env on the VPS. Owner: knowra, mode: 0600.
# systemd's knowra-web.service loads this via EnvironmentFile=.

# ---- Required ----
DATABASE_URL=postgres://user:password@host.neon.tech/knowra?sslmode=require

# ---- LLM hooks ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Wikipedia ----
WIKIPEDIA_USER_AGENT="Knowra/1.0 (contact: dev@knowra.space)"

# ---- Cloudflare Images (optional — image CDN + blurhash) ----
CF_IMAGES_ACCOUNT_ID=
CF_IMAGES_API_TOKEN=

# ---- Upstash Redis (optional — cache for Wikipedia API responses) ----
# Without these, every Trending / On-this-day / Search request hits
# Wikipedia directly (~1-2s). With them, repeat requests are ~10ms.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Clerk auth (optional — only needed once web sign-in is wired) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Daily digest cron secret (required to send push notifications) ----
# The /api/cron/daily-digest route is gated on a Bearer token match.
# The systemd timer (knowra-digest-cron.timer) reads this same .env and
# passes the secret in the Authorization header. Generate one with:
#   openssl rand -base64 32
# Without it set, the route refuses every request (including the timer's),
# so the daily push fan-out silently stops.
CRON_SECRET=

# ---- Runtime ----
NODE_ENV=production
# Must match the `proxy_pass http://127.0.0.1:NNNN` line in
# deploy/nginx-knowra.conf. We use 3033 because ports 3000 and 3001
# are already taken by other apps on this VPS. If you're deploying
# somewhere new with nothing else running, 3000 is fine too — just
# keep both files in sync.
PORT=3033
