# /opt/knowra/.env on the VPS. Owner: knowra, mode: 0600.
# systemd's knowra-web.service loads this via EnvironmentFile=.

# ---- Required ----
DATABASE_URL=postgres://user:password@host.neon.tech/knowra?sslmode=require

# ---- LLM hooks ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Wikipedia ----
WIKIPEDIA_USER_AGENT="Knowra/1.0 (contact: dev@knowra.space)"

# ---- Cloudflare Images (optional — image CDN + blurhash) ----
CF_IMAGES_ACCOUNT_ID=
CF_IMAGES_API_TOKEN=

# ---- Clerk auth (optional — only needed once web sign-in is wired) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Runtime ----
NODE_ENV=production
# Must match the `reverse_proxy localhost:NNNN` line in deploy/Caddyfile.
# We use 3001 because port 3000 is already taken by another Docker app
# on the VPS. If you're deploying somewhere new with nothing on 3000,
# change both to 3000.
PORT=3001
