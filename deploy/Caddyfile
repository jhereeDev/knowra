# Caddy reverse proxy for Knowra. Caddy auto-manages TLS via Let's
# Encrypt — your VPS just needs ports 80 and 443 open and the DNS A
# records for knowra.space + www.knowra.space pointing at this server.
#
# Reload after changes: sudo systemctl reload caddy
# Tail logs:           sudo tail -f /var/log/caddy/knowra-access.log

knowra.space {
	encode gzip zstd

	# Forward to the Next.js app. Port must match PORT in /opt/knowra/.env.
	# Default 3000; production VPS uses 3033 (3000 + 3001 are taken).
	reverse_proxy localhost:3033 {
		# Pass through the client's real IP so the app can log + rate-limit.
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto https
	}

	# Cache static Next.js asset bundles aggressively — they're hashed.
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# Security headers — cheap insurance.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# Don't leak server identity.
		-Server
	}

	log {
		output file /var/log/caddy/knowra-access.log {
			roll_size 50mb
			roll_keep 7
		}
		format json
	}
}

# Redirect www → apex for SEO consistency.
www.knowra.space {
	redir https://knowra.space{uri} permanent
}
